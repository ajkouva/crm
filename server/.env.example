# ── Database ──────────────────────────────────────────────────────────────────
# Local: postgresql://user:password@localhost:5432/pscrm
# Production (Supabase/Neon/Railway): paste your connection string here
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/pscrm

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_64_CHAR_RANDOM_STRING

# ── CORS ───────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=https://your-frontend-domain.com

# ── AI Classification (Gemini) ─────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Ollama (optional local AI fallback) ───────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
# Use an App Password (not your real password): https://myaccount.google.com/apppasswords
EMAIL_PASS=your-16-char-app-password
